# Docker Registry UI - Environment Variables
# NOTE:
# - Registry definitions are NOT configured here.
# - Registry definitions live only in registries.config.json.
# - The only registry-related variable allowed here is CONFIG_FILE path.

# Path to registries configuration file
CONFIG_FILE=/app/registries.config.json

# App mode: true = read-only, false = allow destructive operations
READ_ONLY=true

# Generic request timeout to registry/scanner APIs (seconds)
TIMEOUT=10

# Poll/check interval used by legacy flows (seconds)
CHECK_INTERVAL=300

# Footer/build metadata shown in UI
BUILT_BY=Vibhuvi OiO & Others

# SQLite database path used to persist vulnerability scan results
DB_PATH=/app/data/scan_results.db

# -----------------------------------------------------------------------------
# Daily massive scan scheduler
# -----------------------------------------------------------------------------
MASSIVE_SCAN_SCHEDULE_ENABLED=false
MASSIVE_SCAN_SCHEDULE_TIME=02:00
MASSIVE_SCAN_TIMEZONE=Europe/Rome
MASSIVE_SCAN_REGISTRIES=all
MASSIVE_SCAN_REPO_PATTERN=*
MASSIVE_SCAN_MODE=all
MASSIVE_SCAN_AGE_VALUE=
MASSIVE_SCAN_AGE_UNIT=days
MASSIVE_SCAN_INCLUDE_ALL_TAGS=true
MASSIVE_SCAN_DRY_RUN=false

# -----------------------------------------------------------------------------
# Recap notifications - Email (SMTP)
# -----------------------------------------------------------------------------
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_SMTP_PORT=587
NOTIFY_EMAIL_USE_TLS=true
NOTIFY_EMAIL_SMTP_USER=
NOTIFY_EMAIL_SMTP_PASSWORD=
NOTIFY_EMAIL_FROM=
NOTIFY_EMAIL_TO=

# -----------------------------------------------------------------------------
# Recap notifications - Telegram
# -----------------------------------------------------------------------------
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
